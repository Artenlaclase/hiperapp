generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           Int      @id @default(autoincrement())
  name         String
  email        String   @unique
  password     String
  age          Int?
  gender       String?
  weight       Float?
  height       Float?
  activityLevel String?
  htaLevel     String? @map("hta_level")
  refreshToken String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  BP                BloodPressureRecord[]
  foodLogs          FoodLog[]
  mealPlans         MealPlan[]
  medications       Medication[]
  medicationLogs    MedicationLog[]
  medicationAlarms  MedicationAlarm[]
  habitLogs         HabitLog[]
}

model BloodPressureRecord {
  id         Int      @id @default(autoincrement())
  systolic   Int
  diastolic  Int
  measuredAt DateTime
  userId     Int
  user       User     @relation(fields: [userId], references: [id])
  createdAt  DateTime @default(now())
}

model Food {
  id          Int     @id @default(autoincrement())
  name        String
  sodiumLevel String? @map("sodium_level")
  potassium   String? @map("potassium_level")
  category    String?
  createdAt   DateTime @default(now())
  logs        FoodLog[]
}

model FoodLog {
  id         Int      @id @default(autoincrement())
  foodId     Int
  portion    String
  consumedAt DateTime
  userId     Int
  user       User     @relation(fields: [userId], references: [id])
  food       Food     @relation(fields: [foodId], references: [id])
  createdAt  DateTime @default(now())
}

model MealPlan {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
  weekStart DateTime @map("week_start")
  notes     String?
  createdAt DateTime @default(now())
}

model Medication {
  id           Int      @id @default(autoincrement())
  name         String
  dosage       String
  instructions String?
  alarms       MedicationAlarm[]
  logs         MedicationLog[]
  userId       Int
  user         User     @relation(fields: [userId], references: [id])
  createdAt    DateTime @default(now())
}

model MedicationAlarm {
  id         Int      @id @default(autoincrement())
  medicationId Int
  alarmTime  String
  daysOfWeek String
  active     Boolean  @default(true)
  medication Medication @relation(fields: [medicationId], references: [id])
  userId     Int?
  user       User?     @relation(fields: [userId], references: [id])
  createdAt  DateTime @default(now())
}

model MedicationLog {
  id           Int      @id @default(autoincrement())
  medicationId Int
  takenAt      DateTime
  status       String
  medication   Medication @relation(fields: [medicationId], references: [id])
  userId       Int
  user         User     @relation(fields: [userId], references: [id])
  createdAt    DateTime @default(now())
}

model EducationalContent {
  id        Int      @id @default(autoincrement())
  title     String
  content   String
  topic     String?
  level     String?
  createdAt DateTime @default(now())
}

model Habit {
  id        Int      @id @default(autoincrement())
  name      String
  description String?
  createdAt DateTime @default(now())
  habitLogs HabitLog[]
}

model HabitLog {
  id         Int      @id @default(autoincrement())
  userId     Int
  habitId    Int
  user       User     @relation(fields: [userId], references: [id])
  habit      Habit    @relation(fields: [habitId], references: [id])
  completedAt DateTime
  createdAt  DateTime @default(now())
}


