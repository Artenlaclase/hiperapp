{
  "name": "apphiper-backend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "start:dev": "ts-node-dev --respawn --transpile-only src/main.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/main.js",
    "prisma": "prisma",
    "test": "jest --runInBand",
    "test:unit": "jest --runInBand --testPathPatterns=src/.*\\.spec\\.ts$",
    "test:e2e": "jest --runInBand --testPathPatterns=test/.*\\.spec\\.ts$",
    "test:watch": "jest --watchAll"
  },
  "dependencies": {
    "@nestjs/common": "10.0.0",
    "@nestjs/core": "10.0.0",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/passport": "^10.0.0",
    "@nestjs/platform-express": "10.0.0",
    "@prisma/client": "5.10.1",
    "bcryptjs": "^2.4.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "passport": "^0.6.0",
    "passport-jwt": "^4.0.1",
    "reflect-metadata": "0.1.13",
    "rxjs": "7.8.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/jest": "^30.0.0",
    "@types/node": "20.4.2",
    "@types/supertest": "^7.2.1",
    "jest": "^30.4.2",
    "prisma": "5.10.1",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.11",
    "ts-node-dev": "2.0.0",
    "typescript": "5.2.2"
  }
}